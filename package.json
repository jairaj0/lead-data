{
  "name": "lead-data",
  "version": "1.2.8",
  "description": "Local lead manager — JSON hi database, koi CSV nahi. macOS desktop app (Electron).",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.leaddata.app",
    "productName": "Lead Data",
    "files": [
      "main.js",
      "preload.js",
      "leadstore.js",
      "whatsapp.js",
      "public/**/*",
      "build/icon.png"
    ],
    "asarUnpack": [
      "**/node_modules/puppeteer/**",
      "**/node_modules/puppeteer-core/**",
      "**/node_modules/whatsapp-web.js/**"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.7"
  }
}
